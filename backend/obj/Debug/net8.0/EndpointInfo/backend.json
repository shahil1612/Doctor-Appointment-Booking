  "components": {
    "schemas": {
      "AppointmentDecisionAction": {
        "enum": [
          "approve",
          "decline"
        ],
        "type": "string"
      },
      "AppointmentDecisionRequest": {
        "required": [
          "decision"
        ],
        "type": "object",
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/AppointmentDecisionAction"
          },
          "doctorNotes": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CancelAppointmentRequest": {
        "required": [
          "doctorNotes"
        ],
        "type": "object",
        "properties": {
          "doctorNotes": {
            "maxLength": 500,
            "minLength": 3,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAppointmentRequest": {
        "required": [
          "doctorUserId",
          "reason",
          "slotId"
        ],
        "type": "object",
        "properties": {
          "doctorUserId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "slotId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "reason": {
            "maxLength": 500,
            "minLength": 5,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateAppointmentSlotRequest": {
        "required": [
          "clinicId",
          "slotEndUtc",
          "slotStartUtc"
        ],
        "type": "object",
        "properties": {
          "clinicId": {
            "type": "integer",
            "format": "int32"
          },
          "slotStartUtc": {
            "type": "string",
            "format": "date-time"
          },
          "slotEndUtc": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "CreateClinicRequest": {
        "required": [
          "addressLine",
          "city",
          "consultationFee",
          "name",
          "pincode",
          "state"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "addressLine": {
            "maxLength": 200,
            "minLength": 5,
            "type": "string"
          },
          "city": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string"
          },
          "state": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string"
          },
          "pincode": {
            "minLength": 1,
            "pattern": "^[0-9]{6}$",
            "type": "string"
          },
          "consultationFee": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "latitude": {
            "maximum": 90,
            "minimum": -90,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "longitude": {
            "maximum": 180,
            "minimum": -180,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "phone": {
            "pattern": "^$|^[0-9]{10}$",
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "email",
          "password",
          "userType"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "userType": {
            "$ref": "#/components/schemas/UserType"
          }
        },
        "additionalProperties": false
      },
      "SignupRequest": {
        "required": [
          "dob",
          "email",
          "fullName",
          "password",
          "phone",
          "userType"
        ],
        "type": "object",
        "properties": {
          "userType": {
            "$ref": "#/components/schemas/UserType"
          },
          "fullName": {
            "maxLength": 100,
            "minLength": 3,
            "pattern": "^[a-zA-Z ]+$",
            "type": "string"
          },
          "email": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^[0-9]{10}$",
            "type": "string"
          },
          "dob": {
            "type": "string",
            "format": "date-time"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "emergencyContact": {
            "pattern": "^$|^[0-9]{10}$",
            "type": "string",
            "nullable": true
          },
          "allergies": {
            "type": "string",
            "nullable": true
          },
          "specialization": {
            "type": "string",
            "nullable": true
          },
          "licenseNumber": {
            "type": "string",
            "nullable": true
          },
          "yearsExperience": {
            "maximum": 60,
            "minimum": 0,
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateDoctorProfileRequest": {
        "type": "object",
        "properties": {
          "specialization": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "licenseNumber": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "yearsExperience": {
            "maximum": 60,
            "minimum": 0,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "bio": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          },
          "consultationFee": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdatePatientProfileRequest": {
        "type": "object",
        "properties": {
          "emergencyContact": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "allergies": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "bloodGroup": {
            "maxLength": 10,
            "type": "string",
            "nullable": true
          },
          "heightCm": {
            "maximum": 300,
            "minimum": 0,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "weightKg": {
            "maximum": 500,
            "minimum": 0,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "chronicConditions": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserType": {
        "enum": [
          "patient",
          "doctor"
        ],
        "type": "string"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter your JWT token in the text input below.\n\nExample: \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}